<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.trabajo_cafeteria.controlador.ClienteController"
            prefHeight="400.0" prefWidth="600.0">
    <VBox alignment="CENTER" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>
        <Label text="Gestión de Clientes" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <TextField fx:id="txtNombre" promptText="Nombre"/>
        <TextField fx:id="txtTelefono" promptText="Teléfono"/>
        <TextField fx:id="txtEmail" promptText="Email"/>
        <HBox spacing="10.0" alignment="CENTER">
            <Button text="Guardar" onAction="#guardarCliente"/>
            <Button text="Buscar" onAction="#buscarCliente"/>
            <Button text="Eliminar" onAction="#eliminarCliente"/>
        </HBox>
    </VBox>
</AnchorPane>
