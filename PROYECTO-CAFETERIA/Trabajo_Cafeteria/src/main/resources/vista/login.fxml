<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.trabajo_cafeteria.controlador.LoginController"
            prefHeight="300.0" prefWidth="400.0">
    <VBox alignment="CENTER" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>
        <Label text="Inicio de Sesión" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <TextField fx:id="txtUsuario" promptText="Usuario"/>
        <PasswordField fx:id="txtContrasena" promptText="Contraseña"/>
        <Button text="Iniciar Sesión" onAction="#iniciarSesion"/>
    </VBox>
</AnchorPane>
